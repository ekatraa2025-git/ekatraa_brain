# Copy to .env and fill in keys. SARVAM_API_KEY is shared with ekatraa_backend.

SARVAM_API_KEY=
EKATRAA_BACKEND_URL=http://localhost:3000

# Daily.co WebRTC (recommended transport — reliable mic permissions in browser)
# Create a free API key at https://dashboard.daily.co/developers
DAILY_API_KEY=

# Optional: reuse a fixed room instead of creating one per session
# DAILY_ROOM_URL=https://your-domain.daily.co/your-room

PIPECAT_VOICE_AGENT=customer
PIPECAT_VOICE_LANG=en-IN
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=priya
SARVAM_STT_MODEL=saaras:v3
